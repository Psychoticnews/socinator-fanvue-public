<UserControl
    x:Class="FanvueDominatorUI.TabManager.AnalyticsTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0"
                Background="#2D2D30"
                BorderBrush="#555555"
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title and Account Selector -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Analytics Dashboard"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                    <TextBlock Text="Account:"
                               FontSize="13"
                               Foreground="#AAAAAA"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                    <ComboBox x:Name="CmbAccountSelector"
                              Width="220"
                              Height="30"
                              SelectionChanged="CmbAccountSelector_SelectionChanged"
                              Background="#1E1E1E"
                              Foreground="White"
                              BorderBrush="#555555"
                              FontSize="13"/>

                    <TextBlock Text="Time Range:"
                               FontSize="13"
                               Foreground="#AAAAAA"
                               VerticalAlignment="Center"
                               Margin="20,0,8,0"/>

                    <ComboBox x:Name="CmbTimeRange"
                              Width="220"
                              Height="30"
                              SelectionChanged="CmbTimeRange_SelectionChanged"
                              Background="#1E1E1E"
                              Foreground="White"
                              BorderBrush="#555555"
                              FontSize="13"/>

                    <Button x:Name="BtnExport"
                            Click="BtnExport_Click"
                            Height="30"
                            Margin="20,0,0,0"
                            Padding="12,0"
                            Background="#1E1E1E"
                            Foreground="White"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="Export summary metrics as CSV or JSON">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M5,20 L19,20 L19,18 L5,18 Z M12,3 L7,8 L8.5,9.5 L11,7 L11,15 L13,15 L13,7 L15.5,9.5 L17,8 Z"
                                  Fill="#E0E0E0"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="Export"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#E0E0E0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Last Updated + Cache Status (#V.3) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock x:Name="TxtCacheStatus"
                               Text=""
                               FontSize="11"
                               Foreground="#FFD700"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtLastUpdated"
                               Text=""
                               FontSize="11"
                               Foreground="#888888"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Refresh Button -->
                <Button x:Name="BtnRefresh"
                        Grid.Column="2"
                        Click="BtnRefresh_Click"
                        Height="30"
                        Background="{DynamicResource AccentBaseColorBrush}"
                        Foreground="White"
                        Cursor="Hand">
                    <Button.Content>
                        <TextBlock Text="Refresh"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="15,0"/>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: API error banner (#V.4) -->
                    <RowDefinition Height="Auto"/>  <!-- 1: stats cards -->
                    <RowDefinition Height="Auto"/>  <!-- 2: 24h tile row (#V.5) -->
                    <RowDefinition Height="Auto"/>  <!-- 3: Growth Tracker -->
                    <RowDefinition Height="Auto"/>  <!-- 4: charts row -->
                    <RowDefinition Height="Auto"/>  <!-- 5: account breakdown -->
                    <RowDefinition Height="Auto"/>  <!-- 6: recent spending -->
                    <RowDefinition Height="Auto"/>  <!-- 7: bottom switchable list panel -->
                </Grid.RowDefinitions>

                <!-- Row 0: API Error Banner (#V.4) — replaces inline "Couldn't fetch data" overlay. -->
                <Border x:Name="BorderApiErrorBanner"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        Background="#3D1F1F"
                        BorderBrush="#F44336"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtApiErrorMessage"
                                   Grid.Column="0"
                                   Text="API error — couldn't fetch latest data."
                                   Foreground="#F44336"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnDismissApiError"
                                Grid.Column="1"
                                Content="✕"
                                Width="24" Height="24"
                                Background="Transparent"
                                Foreground="#F44336"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnDismissApiError_Click"/>
                    </Grid>
                </Border>

                <!-- Row 1: Main Stats Cards -->
                <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,15">
                    <!-- Followers Card -->
                    <Border Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="FOLLOWERS"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtFollowers"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#3897F0"/>
                        </StackPanel>
                    </Border>

                    <!-- Subscribers Card -->
                    <Border Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock Text="SUBSCRIBERS"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtSubscribers"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#EE6544"/>
                        </StackPanel>
                    </Border>

                    <!-- Monthly Earnings Card -->
                    <Border Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock Text="THIS MONTH"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtMonthEarnings"
                                       Text="$0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#28A745"/>
                            <TextBlock x:Name="TxtMonthChange"
                                       Text=""
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Earnings Card -->
                    <Border Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL EARNINGS"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtTotalEarnings"
                                       Text="$0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#FFD700"/>
                            <TextBlock Text="All-time gross"
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="0,2,0,0"/>
                            <TextBlock x:Name="TxtNetEarnings"
                                       Text=""
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Row 2: 24-hour stat tiles (#V.5) — always visible, independent of CmbTimeRange. -->
                <UniformGrid Grid.Row="2" Rows="1" Columns="3" Margin="0,0,0,15">
                    <Border Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="EARNED LAST 24H"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtEarned24h"
                                       Text="$0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#FFD700"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock Text="SUBSCRIBERS GAINED LAST 24H"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtSubs24h"
                                       Text="0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="FOLLOWERS GAINED LAST 24H"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtFollowers24h"
                                       Text="0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Row 3: Growth Tracker (independent of main time-range selector) -->
                <Border Grid.Row="3"
                        Background="#2D2D30"
                        BorderBrush="#555555"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header: title + window selector -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Growth Tracker"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="GrowthWindowSelector"
                                      Grid.Column="1"
                                      Width="160"
                                      Height="28"
                                      SelectionChanged="GrowthWindowSelector_SelectionChanged"
                                      Background="#1E1E1E"
                                      Foreground="White"
                                      BorderBrush="#555555"
                                      FontSize="12"/>
                        </Grid>

                        <!-- Two side-by-side stat tiles -->
                        <UniformGrid Grid.Row="1" Rows="1" Columns="2">
                            <Border Background="#1E1E1E"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="FOLLOWERS GAINED"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#888888"
                                               Margin="0,0,0,6"/>
                                    <TextBlock x:Name="TxtFollowersGained"
                                               Text="0"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Foreground="#4CAF50"/>
                                    <TextBlock x:Name="TxtGrowthFollowersSub"
                                               Text=""
                                               FontSize="11"
                                               Foreground="#B0B0B0"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1E1E1E"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="SUBSCRIBERS GAINED"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#888888"
                                               Margin="0,0,0,6"/>
                                    <TextBlock x:Name="TxtSubscribersGained"
                                               Text="0"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Foreground="#4CAF50"/>
                                    <TextBlock x:Name="TxtGrowthSubscribersSub"
                                               Text=""
                                               FontSize="11"
                                               Foreground="#B0B0B0"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- Row 2: Charts Row -->
                <Grid Grid.Row="4" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>

                    <!-- Earnings Bar Chart (collapsible — see EarningsSection_HeaderClick handler) -->
                    <Border Grid.Column="0"
                            Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <!-- Clickable section header: chevron + title. MouseLeftButtonUp -> handler. -->
                            <Border x:Name="EarningsSectionHeader"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="EarningsSection_HeaderClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtEarningsChevron"
                                               Text="▼"
                                               FontSize="12"
                                               Foreground="#E0E0E0"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtBarChartTitle"
                                               Text="Monthly Earnings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Grid x:Name="EarningsSectionContent" Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- controls strip: Show toggles + Chart type -->
                                    <RowDefinition Height="*"/>     <!-- canvas -->
                                    <RowDefinition Height="Auto"/>  <!-- legend -->
                                    <RowDefinition Height="Auto"/>  <!-- reconciliation -->
                                </Grid.RowDefinitions>

                                <!-- Chart-specific controls live INSIDE the chart panel (#H). They collapse with the section. -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Show:"
                                                   FontSize="13"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <!-- #V.2 — single-series mutex toggles. Default = Gross. -->
                                        <ToggleButton x:Name="ToggleEarningsGross"     Content="Earnings (Gross)"     IsChecked="True"
                                                      Checked="ChartSeriesToggle_Changed" Unchecked="ChartSeriesToggle_Changed"
                                                      Margin="0,0,6,0" Padding="10,4"/>
                                        <ToggleButton x:Name="ToggleEarningsNet"       Content="Earnings (Net)"
                                                      Checked="ChartSeriesToggle_Changed" Unchecked="ChartSeriesToggle_Changed"
                                                      Margin="0,0,6,0" Padding="10,4"/>
                                        <ToggleButton x:Name="ToggleFollowersGained"   Content="Followers Gained"
                                                      Checked="ChartSeriesToggle_Changed" Unchecked="ChartSeriesToggle_Changed"
                                                      Margin="0,0,6,0" Padding="10,4"/>
                                        <ToggleButton x:Name="ToggleSubscribersGained" Content="Subscribers Gained"
                                                      Checked="ChartSeriesToggle_Changed" Unchecked="ChartSeriesToggle_Changed"
                                                      Margin="0,0,6,0" Padding="10,4"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Chart:"
                                                   FontSize="13"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,8,0"/>
                                        <ComboBox x:Name="ChartTypeSelector"
                                                  Width="100"
                                                  Height="28"
                                                  SelectionChanged="ChartTypeSelector_SelectionChanged"
                                                  Background="#1E1E1E"
                                                  Foreground="White"
                                                  BorderBrush="#555555"
                                                  FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Bar Chart Canvas -->
                                <Canvas x:Name="EarningsChart"
                                        Grid.Row="1"
                                        Height="200"
                                        Background="Transparent"
                                        ClipToBounds="True"/>

                                <!-- Source Legend (color = source, value = totals across selected range) -->
                                <ItemsControl x:Name="EarningsSourceLegend"
                                              Grid.Row="2"
                                              Margin="30,8,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                                                <Rectangle Width="10"
                                                           Height="10"
                                                           Fill="{Binding SwatchBrush}"
                                                           RadiusX="2"
                                                           RadiusY="2"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="11"
                                                           Foreground="#E0E0E0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ValueText}"
                                                           FontSize="11"
                                                           Foreground="#B0B0B0"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Reconciliation total: makes Sources sum vs Bars sum visible to the user. -->
                                <TextBlock x:Name="TxtSourceReconciliation"
                                           Grid.Row="3"
                                           Text=""
                                           FontSize="11"
                                           Foreground="#B0B0B0"
                                           Margin="30,4,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Revenue Breakdown Pie Chart -->
                    <Border Grid.Column="1"
                            Background="#2D2D30"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="15"
                            Margin="8,0,0,0">
                        <StackPanel>
                            <Border x:Name="RevenueSectionHeader"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="RevenueSection_HeaderClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtRevenueChevron"
                                               Text="▼"
                                               FontSize="12"
                                               Foreground="#E0E0E0"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                        <TextBlock Text="Revenue Breakdown"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                        <TextBlock x:Name="TxtPieRangeLabel"
                                                   Text=""
                                                   FontSize="11"
                                                   Foreground="#888888"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel x:Name="RevenueSectionContent" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ToggleButton x:Name="PieModeBySource"
                                                  Content="By Source"
                                                  IsChecked="True"
                                                  Checked="PieMode_Checked"
                                                  Margin="0,0,4,0"
                                                  Padding="10,4"/>
                                    <ToggleButton x:Name="PieModeByType"
                                                  Content="By Type"
                                                  Checked="PieMode_Checked"
                                                  Margin="0,0,4,0"
                                                  Padding="10,4"/>
                                </StackPanel>

                                <!-- Gross/Net value-mode sub-toggle (#O.2). Net is default. Mutually exclusive. -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="Values:"
                                               FontSize="11"
                                               Foreground="#B0B0B0"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <ToggleButton x:Name="PieValueGross"
                                                  Content="Gross"
                                                  Checked="PieValue_Checked"
                                                  Margin="0,0,4,0"
                                                  Padding="10,3"
                                                  FontSize="11"/>
                                    <ToggleButton x:Name="PieValueNet"
                                                  Content="Net"
                                                  IsChecked="True"
                                                  Checked="PieValue_Checked"
                                                  Margin="0,0,4,0"
                                                  Padding="10,3"
                                                  FontSize="11"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Pie Chart Canvas -->
                                    <Canvas x:Name="PieChart"
                                            Grid.Column="0"
                                            Width="150"
                                            Height="150"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                    <!-- Legend (dynamic, populated by DrawPieChart per selected mode) -->
                                    <ItemsControl x:Name="PieLegend"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  Margin="15,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Rectangle Width="12"
                                                               Height="12"
                                                               Fill="{Binding SwatchBrush}"
                                                               RadiusX="2"
                                                               RadiusY="2"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="12"
                                                               Foreground="#E0E0E0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ValueText}"
                                                               FontSize="11"
                                                               Foreground="#B0B0B0"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 5: Account Breakdown (for All Accounts view) -->
                <Border x:Name="AccountBreakdownPanel"
                        Grid.Row="5"
                        Background="#2D2D30"
                        BorderBrush="#555555"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,15"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <Border x:Name="AccountsSectionHeader"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="AccountsSection_HeaderClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtAccountsChevron"
                                               Text="▼"
                                               FontSize="12"
                                               Foreground="#E0E0E0"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Account Breakdown"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBox x:Name="TxtAccountBreakdownSearch"
                                     TextChanged="TxtAccountBreakdownSearch_TextChanged"
                                     Padding="6,4"
                                     Margin="0,8,0,0"
                                     Background="#1E1E1E"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     FontSize="12"
                                     ToolTip="Filter by username"/>
                        </StackPanel>

                        <ScrollViewer x:Name="AccountBreakdownScroll"
                                      Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly"
                                      MaxHeight="400">
                        <ItemsControl x:Name="AccountBreakdownList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E1E"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Username}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="20,0">
                                                <TextBlock Text="Followers"
                                                           FontSize="10"
                                                           Foreground="#888888"/>
                                                <TextBlock Text="{Binding Followers}"
                                                           FontSize="13"
                                                           Foreground="#3897F0"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Margin="20,0">
                                                <TextBlock Text="Subscribers"
                                                           FontSize="10"
                                                           Foreground="#888888"/>
                                                <TextBlock Text="{Binding Subscribers}"
                                                           FontSize="13"
                                                           Foreground="#EE6544"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Margin="20,0">
                                                <TextBlock Text="This Month"
                                                           FontSize="10"
                                                           Foreground="#888888"/>
                                                <TextBlock Text="{Binding MonthEarnings}"
                                                           FontSize="13"
                                                           Foreground="#28A745"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4" Margin="20,0,0,0">
                                                <TextBlock Text="Total"
                                                           FontSize="10"
                                                           Foreground="#888888"/>
                                                <TextBlock Text="{Binding TotalEarnings}"
                                                           FontSize="13"
                                                           Foreground="#FFD700"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Row 6: Recent Spending (single account view) -->
                <Border x:Name="RecentSpendingPanel"
                        Grid.Row="6"
                        Background="#2D2D30"
                        BorderBrush="#555555"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,15"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Recent Spending"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtRecentSpendingSearch"
                                     TextChanged="TxtRecentSpendingSearch_TextChanged"
                                     Padding="6,4"
                                     Background="#1E1E1E"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     FontSize="12"
                                     ToolTip="Filter by fan handle"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly"
                                      MaxHeight="300">
                        <ItemsControl x:Name="RecentSpendingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E1E"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Date}"
                                                       FontSize="12"
                                                       Foreground="#888888"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,15,0"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Fan}"
                                                       FontSize="13"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Source}"
                                                       FontSize="11"
                                                       Foreground="#AAAAAA"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,15,0"/>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Gross}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource GreenColorAccordingTheme}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="TxtNoSpending"
                                   Grid.Row="1"
                                   Text="No recent spending"
                                   FontSize="12"
                                   Foreground="#888888"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Row 7: Combined Recent Activity panel (switchable: Top Spenders / Newest Subscribers) -->
                <Border Grid.Row="7"
                        Background="#2D2D30"
                        BorderBrush="#555555"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15"
                        MaxHeight="320">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header: switcher dropdown + collapse toggle + contextual hint -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="BottomListSelector"
                                      Grid.Column="0"
                                      Width="200"
                                      Height="30"
                                      SelectionChanged="BottomListSelector_SelectionChanged"
                                      Background="#1E1E1E"
                                      Foreground="White"
                                      BorderBrush="#555555"
                                      FontSize="13"/>

                            <Border x:Name="BottomListSectionHeader"
                                    Grid.Column="1"
                                    Background="#1E1E1E"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    Width="28"
                                    Height="28"
                                    Margin="8,0,0,0"
                                    Cursor="Hand"
                                    ToolTip="Collapse / expand list"
                                    MouseLeftButtonUp="BottomListSection_HeaderClick">
                                <TextBlock x:Name="TxtBottomListChevron"
                                           Text="▼"
                                           FontSize="11"
                                           Foreground="#E0E0E0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="TxtTopSpendersHint"
                                       Grid.Column="2"
                                       Text="All-time data — not affected by time range."
                                       FontSize="11"
                                       Foreground="#B0B0B0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="10,0,0,0"
                                       Visibility="Visible"/>
                        </Grid>

                        <!-- Search row: only the search box for the active list is visible -->
                        <Grid x:Name="BottomListSearchRow" Grid.Row="1" Margin="0,0,0,8">
                            <TextBox x:Name="TxtTopSpendersSearch"
                                     TextChanged="TxtTopSpendersSearch_TextChanged"
                                     Padding="6,3"
                                     Background="#1E1E1E"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     FontSize="11"
                                     ToolTip="Filter by fan handle"
                                     Visibility="Visible"/>
                            <TextBox x:Name="TxtRecentSubscribersSearch"
                                     TextChanged="TxtRecentSubscribersSearch_TextChanged"
                                     Padding="6,3"
                                     Background="#1E1E1E"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     FontSize="11"
                                     ToolTip="Filter by username"
                                     Visibility="Collapsed"/>
                        </Grid>

                        <!-- Content area: stacked lists, visibility toggled by BottomListSelector -->
                        <Grid x:Name="BottomListContent" Grid.Row="2">
                            <ScrollViewer x:Name="TopSpendersScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PanningMode="VerticalOnly"
                                          MaxHeight="240"
                                          Visibility="Visible">
                                <ItemsControl x:Name="TopSpendersList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E1E1E"
                                                    CornerRadius="4"
                                                    Padding="10"
                                                    Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Rank}"
                                                               FontSize="12"
                                                               Foreground="#FFD700"
                                                               FontWeight="Bold"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Fan}"
                                                               FontSize="12"
                                                               Foreground="White"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding TotalGross}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource GreenColorAccordingTheme}"
                                                               FontWeight="SemiBold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <ScrollViewer x:Name="RecentSubscribersScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PanningMode="VerticalOnly"
                                          MaxHeight="240"
                                          Visibility="Collapsed">
                                <ItemsControl x:Name="RecentSubscribersList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E1E1E"
                                                    CornerRadius="4"
                                                    Padding="10"
                                                    Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Username}"
                                                               FontSize="12"
                                                               Foreground="White"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Time}"
                                                               FontSize="11"
                                                               Foreground="#B0B0B0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock x:Name="TxtNoTopSpenders"
                                       Text="No top spenders yet"
                                       FontSize="12"
                                       Foreground="#B0B0B0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <TextBlock x:Name="TxtNoSubscribers"
                                       Text="No recent subscribers"
                                       FontSize="12"
                                       Foreground="#B0B0B0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay"
                Grid.RowSpan="2"
                Background="#CC1E1E1E"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TxtLoadingStatus"
                           Text="Loading analytics..."
                           FontSize="14"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- No Accounts Message -->
        <Border x:Name="NoAccountsPanel"
                Grid.RowSpan="2"
                Background="#1E1E1E"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="No Fanvue accounts connected"
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Go to Setup tab to add an account"
                           FontSize="13"
                           Foreground="#888888"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
