<UserControl
    x:Class="FanvueDominatorUI.Controls.Setup.FanvueSetupWizard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:setup="clr-namespace:FanvueDominatorUI.Controls.Setup"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="{DynamicResource AccentColorBrush}"
                BorderThickness="1"
                CornerRadius="8,8,0,0"
                MinHeight="40"
                Margin="5,0,19,0">
            <StackPanel Orientation="Horizontal" Margin="15,8">
                <TextBlock Text="Fanvue Account Setup"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStepIndicator"
                           Text=" - Manage Multiple Accounts"
                           FontSize="13"
                           Foreground="#CCFFFFFF"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab Control for Setup/Debug -->
        <TabControl Grid.Row="1"
                    Background="Transparent"
                    Margin="5,5,5,5">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                        Background="#2D2D30"
                                        BorderBrush="#555555"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="4,4,0,0"
                                        Margin="0,0,2,0"
                                        Padding="12,6">
                                    <ContentPresenter x:Name="ContentSite"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3D3D40"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#EE6544"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3D3D40"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </TabControl.Resources>

            <!-- Setup Tab -->
            <TabItem Header="Add Accounts">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Connected Accounts Section -->
                        <Border Grid.Row="0"
                                Background="#2D2D30"
                                BorderBrush="#555555"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="5,0,5,15">
                            <StackPanel>
                                <TextBlock Text="Connected Accounts"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,10"/>

                                <!-- Account List -->
                                <ItemsControl x:Name="AccountsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E1E1E"
                                                    BorderBrush="#555555"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="10"
                                                    Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0"
                                                             Width="10"
                                                             Height="10"
                                                             Fill="#28A745"
                                                             Margin="0,0,10,0"
                                                             VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Username, StringFormat=@{0}}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"/>
                                                        <TextBlock Text="{Binding Email}"
                                                                   FontSize="11"
                                                                   Foreground="#AAAAAA"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2"
                                                            Content="Remove"
                                                            Tag="{Binding Username}"
                                                            Click="BtnRemoveAccount_Click"
                                                            Height="25"
                                                            Background="#FF4948"
                                                            Foreground="White"
                                                            FontSize="11"
                                                            Cursor="Hand"
                                                            Padding="8,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- No Accounts Message -->
                                <TextBlock x:Name="TxtNoAccounts"
                                           Text="No accounts connected yet. Add your first account below."
                                           FontSize="12"
                                           Foreground="#AAAAAA"
                                           Visibility="Visible"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Add Account Section -->
                        <Border Grid.Row="1"
                                Background="#2D2D30"
                                BorderBrush="#EE6544"
                                BorderThickness="2"
                                CornerRadius="4"
                                Padding="12"
                                Margin="5,0,5,15">
                            <StackPanel>
                                <TextBlock Text="Add New Account"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#EE6544"
                                           Margin="0,0,0,10"/>

                                <!-- Instructions -->
                                <TextBlock Text="Enter your Fanvue OAuth credentials (same for all accounts), then click Add Account to connect a new Fanvue account."
                                           FontSize="12"
                                           Foreground="#AAAAAA"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,15"/>

                                <!-- Redirect URI -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Redirect URI:"
                                               Width="100"
                                               FontSize="12"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="TxtRedirectUri"
                                             Text="http://127.0.0.1:19876/callback"
                                             Width="280"
                                             Height="28"
                                             IsReadOnly="True"
                                             Background="#1E1E1E"
                                             Foreground="#33CEF2"
                                             BorderThickness="1"
                                             BorderBrush="#555555"
                                             FontSize="11"
                                             FontFamily="Consolas"
                                             VerticalContentAlignment="Center"
                                             Padding="5,0"/>
                                    <Button x:Name="BtnCopyUri"
                                            Click="BtnCopyUri_Click"
                                            Content="Copy"
                                            Height="28"
                                            Margin="5,0,0,0"
                                            Background="#28A745"
                                            Foreground="White"
                                            FontSize="11"
                                            Cursor="Hand"
                                            Padding="10,0"/>
                                </StackPanel>

                                <!-- Client ID Row -->
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                    <TextBlock Text="Client ID:"
                                               Width="100"
                                               FontSize="12"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="TxtClientId"
                                             Width="300"
                                             Height="28"
                                             Controls:TextBoxHelper.Watermark="Enter your Client ID"
                                             Background="Transparent"
                                             BorderThickness="1"
                                             FontWeight="SemiBold"
                                             Foreground="White"
                                             FontSize="12"/>
                                </StackPanel>

                                <!-- Client Secret Row -->
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                    <TextBlock Text="Client Secret:"
                                               Width="100"
                                               FontSize="12"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                    <PasswordBox x:Name="TxtClientSecret"
                                                 Width="300"
                                                 Height="28"
                                                 Background="Transparent"
                                                 BorderThickness="1"
                                                 Foreground="White"
                                                 FontSize="12"/>
                                </StackPanel>

                                <!-- Show Secret Checkbox -->
                                <CheckBox x:Name="ChkShowSecret"
                                          Content="Show secret"
                                          Margin="100,5,5,10"
                                          Foreground="White"
                                          FontSize="11"
                                          Style="{DynamicResource MetroCheckBox}"
                                          Checked="ChkShowSecret_Changed"
                                          Unchecked="ChkShowSecret_Changed"/>

                                <!-- Hidden TextBox for showing secret -->
                                <TextBox x:Name="TxtClientSecretVisible"
                                         Width="300"
                                         Height="28"
                                         Margin="100,0,0,0"
                                         HorizontalAlignment="Left"
                                         Background="Transparent"
                                         BorderThickness="1"
                                         Foreground="White"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Visibility="Collapsed"/>

                                <!-- Status Section -->
                                <Border Background="Transparent"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10"
                                        Margin="0,10,0,10"
                                        MaxWidth="420"
                                        HorizontalAlignment="Left">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <Ellipse x:Name="StatusIndicator"
                                                     Width="10"
                                                     Height="10"
                                                     Fill="#6C757D"
                                                     Margin="0,0,10,0"
                                                     VerticalAlignment="Center"/>
                                            <Controls:ProgressRing x:Name="ConnectProgressRing"
                                                                   IsActive="False"
                                                                   Width="14"
                                                                   Height="14"
                                                                   Margin="0,0,8,0"
                                                                   Foreground="{DynamicResource AccentBaseColorBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="Collapsed"/>
                                            <TextBlock x:Name="TxtConnectionStatus"
                                                       Text="Ready"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtStatusMessage"
                                                   Text="Click 'Add Account' to connect a new Fanvue account."
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="#AAAAAA"/>
                                    </StackPanel>
                                </Border>

                                <!-- Buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Button x:Name="BtnAddAccount"
                                            Click="BtnAddAccount_Click"
                                            Height="35"
                                            Background="#EE6544"
                                            Foreground="White"
                                            Cursor="Hand">
                                        <Button.Content>
                                            <TextBlock Text="Add Account"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Margin="15,0"/>
                                        </Button.Content>
                                    </Button>
                                    <Button x:Name="BtnCancelConnect"
                                            Click="BtnCancelConnect_Click"
                                            Height="35"
                                            Margin="10,0,0,0"
                                            Background="Transparent"
                                            BorderBrush="{DynamicResource AccentBaseColorBrush}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                                            Cursor="Hand"
                                            Visibility="Collapsed">
                                        <Button.Content>
                                            <TextBlock Text="Cancel"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="10,0"/>
                                        </Button.Content>
                                    </Button>
                                    <Button x:Name="BtnOpenPortal"
                                            Click="BtnOpenPortal_Click"
                                            Height="35"
                                            Margin="10,0,0,0"
                                            Background="Transparent"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            Foreground="White"
                                            Cursor="Hand">
                                        <Button.Content>
                                            <TextBlock Text="Open Developer Portal"
                                                       FontSize="12"
                                                       Margin="10,0"/>
                                        </Button.Content>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Help Section -->
                        <Border Grid.Row="2"
                                Background="#2D2D30"
                                BorderBrush="#555555"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="5,0,5,5"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="First Time Setup?"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,8"/>
                                <TextBlock FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,5">
                                    <Run Text="1. Go to Fanvue Developer Portal and create an OAuth app"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,5">
                                    <Run Text="2. Copy the Redirect URI above and add it to your app"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,5">
                                    <Run Text="3. Enter your Client ID and Client Secret above"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap">
                                    <Run Text="4. Click Add Account - your browser will open for authorization"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Analytics Tab -->
            <TabItem Header="Analytics">
                <setup:FanvueAnalyticsControl/>
            </TabItem>

            <!-- Debug Tab -->
            <TabItem Header="Debug Tools">
                <setup:FanvueDebugControl/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
