<UserControl
    x:Class="FanvueDominatorUI.Controls.Setup.FanvueDebugControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10">

            <!-- Header -->
            <TextBlock Text="OAuth Debug Tools"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,15"/>

            <!-- Section 1: Port Status -->
            <Border Background="#2D2D30"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="1. Callback Server Status"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#EE6544"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse x:Name="PortStatusIndicator"
                                 Width="12"
                                 Height="12"
                                 Fill="#6C757D"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtPortStatus"
                                   Text="Port 19876: Unknown"
                                   FontSize="12"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnCheckPort"
                            Click="BtnCheckPort_Click"
                            Content="Check Port Status"
                            Height="28"
                            Width="140"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource AccentBaseColorBrush}"
                            Foreground="White"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Section 2: Test Callback Server -->
            <Border Background="#2D2D30"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="2. Test Callback Server"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#EE6544"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Start a test server and try accessing it in your browser."
                               FontSize="11"
                               Foreground="#AAAAAA"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnStartTestServer"
                                Click="BtnStartTestServer_Click"
                                Content="Start Test Server"
                                Height="28"
                                Width="120"
                                Margin="0,0,10,0"
                                Background="#28A745"
                                Foreground="White"
                                Cursor="Hand"/>
                        <Button x:Name="BtnStopTestServer"
                                Click="BtnStopTestServer_Click"
                                Content="Stop Server"
                                Height="28"
                                Width="100"
                                Background="#FF4948"
                                Foreground="White"
                                Cursor="Hand"
                                IsEnabled="False"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Test URL: "
                                   FontSize="11"
                                   Foreground="#AAAAAA"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTestUrl"
                                   Text="http://127.0.0.1:19876/test"
                                   FontSize="11"
                                   Foreground="#33CEF2"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnOpenTestUrl"
                                Click="BtnOpenTestUrl_Click"
                                Content="Open in Browser"
                                Height="24"
                                Margin="10,0,0,0"
                                Padding="8,0"
                                Background="Transparent"
                                BorderBrush="#555555"
                                Foreground="White"
                                Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtTestServerStatus"
                               Text="Server not running"
                               FontSize="11"
                               Foreground="#6C757D"/>
                </StackPanel>
            </Border>

            <!-- Section 3: Firewall Check -->
            <Border Background="#2D2D30"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="3. Firewall Diagnostics"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#EE6544"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="TxtFirewallStatus"
                               Text="Click to check firewall rules..."
                               FontSize="11"
                               Foreground="#AAAAAA"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnCheckFirewall"
                                Click="BtnCheckFirewall_Click"
                                Content="Check Firewall"
                                Height="28"
                                Width="120"
                                Margin="0,0,10,0"
                                Background="{DynamicResource AccentBaseColorBrush}"
                                Foreground="White"
                                Cursor="Hand"/>
                        <Button x:Name="BtnAddFirewallRule"
                                Click="BtnAddFirewallRule_Click"
                                Content="Add Exception (Admin)"
                                Height="28"
                                Width="150"
                                Background="#FFC107"
                                Foreground="Black"
                                Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Section 4: Log Viewer -->
            <Border Background="#2D2D30"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="4. Logs"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#EE6544"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnOpenLogsFolder"
                                Click="BtnOpenLogsFolder_Click"
                                Content="Open Logs Folder"
                                Height="28"
                                Width="120"
                                Margin="0,0,10,0"
                                Background="{DynamicResource AccentBaseColorBrush}"
                                Foreground="White"
                                Cursor="Hand"/>
                        <Button x:Name="BtnRefreshLogs"
                                Click="BtnRefreshLogs_Click"
                                Content="Refresh"
                                Height="28"
                                Width="80"
                                Background="Transparent"
                                BorderBrush="#555555"
                                Foreground="White"
                                Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock Text="Recent FanvueAuth Logs:"
                               FontSize="11"
                               Foreground="#AAAAAA"
                               Margin="0,0,0,5"/>

                    <Border Background="#1E1E1E"
                            BorderBrush="#333333"
                            BorderThickness="1"
                            CornerRadius="2"
                            MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="TxtLogViewer"
                                     Text="Click 'Refresh' to load recent logs..."
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     Foreground="#00FF00"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     BorderThickness="0"
                                     TextWrapping="Wrap"
                                     Padding="8"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Section 5: Network Test -->
            <Border Background="#2D2D30"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="5. Network Connectivity"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#EE6544"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Test connectivity to Fanvue servers."
                               FontSize="11"
                               Foreground="#AAAAAA"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnTestNetwork"
                            Click="BtnTestNetwork_Click"
                            Content="Test Fanvue Connectivity"
                            Height="28"
                            Width="180"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8"
                            Background="{DynamicResource AccentBaseColorBrush}"
                            Foreground="White"
                            Cursor="Hand"/>

                    <TextBlock x:Name="TxtNetworkStatus"
                               Text=""
                               FontSize="11"
                               Foreground="#AAAAAA"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Section 6: Manual Redirect Test -->
            <Border Background="#2D2D30"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="6. Simulate OAuth Callback"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#EE6544"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Test what happens when Fanvue redirects back. Start the test server first, then click the button below."
                               FontSize="11"
                               Foreground="#AAAAAA"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnSimulateCallback"
                            Click="BtnSimulateCallback_Click"
                            Content="Open Simulated Callback URL"
                            Height="28"
                            Width="200"
                            HorizontalAlignment="Left"
                            Background="#FFC107"
                            Foreground="Black"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Section 7: Configuration Info -->
            <Border Background="#2D2D30"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="7. Current Configuration"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#EE6544"
                               Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Redirect URI:" FontSize="11" Foreground="#AAAAAA" Margin="0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtConfigRedirectUri" Text="http://127.0.0.1:19876/callback" FontSize="11" Foreground="#33CEF2" Margin="0,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Auth URL:" FontSize="11" Foreground="#AAAAAA" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="https://auth.fanvue.com/oauth2/auth" FontSize="11" Foreground="#33CEF2" Margin="0,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Token URL:" FontSize="11" Foreground="#AAAAAA" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="https://auth.fanvue.com/oauth2/token" FontSize="11" Foreground="#33CEF2" Margin="0,2"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="API Base:" FontSize="11" Foreground="#AAAAAA" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="https://api.fanvue.com" FontSize="11" Foreground="#33CEF2" Margin="0,2"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
