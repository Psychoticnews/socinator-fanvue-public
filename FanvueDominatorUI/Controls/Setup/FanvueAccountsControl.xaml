<UserControl
    x:Class="FanvueDominatorUI.Controls.Setup.FanvueAccountsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#1E1E1E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Refresh Button -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Connected Accounts"
                           FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="TxtAccountCount" Text=" (0)"
                           FontSize="24" FontWeight="Light" Foreground="#888888"/>
            </StackPanel>

            <Button x:Name="BtnRefreshAll" Grid.Column="1"
                    Click="BtnRefreshAll_Click"
                    Background="#3897F0" Foreground="White"
                    BorderThickness="0" Padding="20,10"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#128260;" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtRefreshButton" Text="Refresh All" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Accounts List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- No Accounts Message -->
                <Border x:Name="NoAccountsPanel" Visibility="Collapsed"
                        Background="#2D2D30" CornerRadius="8" Padding="40">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#128100;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="No Connected Accounts" FontSize="18" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Go to the Setup tab to connect your Fanvue account"
                                   FontSize="13" Foreground="#888888" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Accounts ItemsControl -->
                <ItemsControl x:Name="AccountsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2D2D30" CornerRadius="8" Margin="0,0,0,15" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Account Header -->
                                    <Grid Grid.Row="0" Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar/Icon -->
                                        <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25"
                                                Background="#3D3D40" Margin="0,0,15,0">
                                            <TextBlock Text="&#128100;" FontSize="24"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Username & Status -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Username}" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{Binding StatusColor}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Last Updated -->
                                        <TextBlock Grid.Column="2" Text="{Binding LastUpdated}"
                                                   FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Stats Row -->
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Followers -->
                                        <Border Grid.Column="0" Background="#3D3D40" CornerRadius="6" Padding="15,12" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="FOLLOWERS" FontSize="10" Foreground="#888888" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Followers}" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Subscribers -->
                                        <Border Grid.Column="1" Background="#3D3D40" CornerRadius="6" Padding="15,12" Margin="4,0">
                                            <StackPanel>
                                                <TextBlock Text="SUBSCRIBERS" FontSize="10" Foreground="#888888" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Subscribers}" FontSize="22" FontWeight="Bold" Foreground="#3897F0" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Revenue Today -->
                                        <Border Grid.Column="2" Background="#3D3D40" CornerRadius="6" Padding="15,12" Margin="4,0">
                                            <StackPanel>
                                                <TextBlock Text="TODAY" FontSize="10" Foreground="#888888" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding RevenueToday}" FontSize="22" FontWeight="Bold" Foreground="#28A745" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Revenue This Week -->
                                        <Border Grid.Column="3" Background="#3D3D40" CornerRadius="6" Padding="15,12" Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="THIS WEEK" FontSize="10" Foreground="#888888" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding RevenueWeek}" FontSize="22" FontWeight="Bold" Foreground="#28A745" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Error Message (if needs reconnection) -->
                                    <Border Grid.Row="2" x:Name="ErrorPanel"
                                            Visibility="{Binding ErrorVisibility}"
                                            Background="#3D2020" CornerRadius="6" Padding="15,10" Margin="0,15,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="&#9888;" FontSize="14" Foreground="#FF6B6B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#FF6B6B" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Reconnect"
                                                    Background="#EE6544" Foreground="White"
                                                    BorderThickness="0" Padding="15,6"
                                                    Click="BtnReconnect_Click"
                                                    Tag="{Binding AccountId}"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="2"
                Background="#CC1E1E1E" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#8987;" FontSize="36" HorizontalAlignment="Center" Foreground="White"/>
                <TextBlock x:Name="TxtLoadingStatus" Text="Loading..."
                           FontSize="14" Foreground="#888888" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
