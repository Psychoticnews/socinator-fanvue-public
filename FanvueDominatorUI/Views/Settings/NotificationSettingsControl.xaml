<UserControl x:Class="FanvueDominatorUI.Views.Settings.NotificationSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource ControlBackgroundBrush}"
             Foreground="{DynamicResource TextColorBrushAccordingTheme}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>
            <TextBlock Text="Notifications"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Text="Poll interval (seconds)"
                       Margin="0,8,0,4" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0"
                        Minimum="30"
                        Maximum="300"
                        TickFrequency="30"
                        IsSnapToTickEnabled="True"
                        Value="{Binding PollIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="1"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           MinWidth="40"
                           Text="{Binding PollIntervalSeconds}" />
            </Grid>

            <TextBlock Text="Notify me about:"
                       Margin="0,16,0,4" />
            <CheckBox Content="New messages"
                      Margin="0,4,0,0"
                      IsChecked="{Binding NotifyNewMessage, Mode=TwoWay}" />
            <CheckBox Content="New subscribers"
                      Margin="0,4,0,0"
                      IsChecked="{Binding NotifyNewSubscriber, Mode=TwoWay}" />
            <CheckBox Content="New followers"
                      Margin="0,4,0,0"
                      IsChecked="{Binding NotifyNewFollower, Mode=TwoWay}" />
            <CheckBox Content="New tips"
                      Margin="0,4,0,0"
                      IsChecked="{Binding NotifyNewTip, Mode=TwoWay}" />

            <Separator Margin="0,20,0,12" />

            <TextBlock Text="Chat Settings"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <CheckBox Content="Auto-mark conversations as read when selected"
                      Margin="0,4,0,0"
                      IsChecked="{Binding AutoMarkReadOnSelection, Mode=TwoWay}" />

            <TextBlock Text="Default mass message audience"
                       Margin="0,16,0,4" />
            <TextBox Text="{Binding DefaultMassMessageAudience, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Audience preset name to pre-select on the Mass Messages tab." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
