<UserControl
    x:Class="FanvueDominatorUI.Views.Settings.ChatterManagerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FanvueDominatorUI.ViewModels.Settings"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="900">
    <UserControl.DataContext>
        <vm:ChatterManagerViewModel />
    </UserControl.DataContext>
    <Grid Background="{DynamicResource UserControlBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                           Text="{DynamicResource LangKeyAccount}" />
                <ComboBox Width="220"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount}"
                          DisplayMemberPath="Display" />
            </StackPanel>
            <Button Grid.Column="1" Padding="14,4"
                    Command="{Binding RefreshCommand}"
                    Content="{DynamicResource LangKeyRefresh}" />
        </Grid>

        <Grid Grid.Row="1" Margin="10,0,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderThickness="1" Margin="0,0,5,0"
                    BorderBrush="{DynamicResource TabBorderSolidBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource AccentBaseColorBrush}" Padding="10,6">
                        <TextBlock Foreground="White" FontWeight="Bold">
                            <Run Text="Team Members (" /><Run Text="{Binding TeamMembers.Count, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>
                    </Border>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding TeamMembers}"
                             SelectedItem="{Binding SelectedMember}"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold"
                                                   Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock FontSize="11" Opacity="0.7"
                                                   Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                                                   Text="{Binding Email}" />
                                        <TextBlock FontSize="11" Opacity="0.7"
                                                   Foreground="{DynamicResource TextColorBrushAccordingTheme}">
                                            <Run Text="Creators: " />
                                            <Run Text="{Binding CreatorCount, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="1" Padding="6,2" VerticalAlignment="Center"
                                            CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ListItemsMouseHoverColorAccordingTheme}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBaseColorBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextColorBrushAccordingTheme}" />
                                                    <Setter Property="Text" Value="CHATTER" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="Text" Value="ADMIN" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderThickness="1" Margin="5,0,0,0"
                    BorderBrush="{DynamicResource TabBorderSolidBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource AccentBaseColorBrush}" Padding="10,6">
                        <TextBlock Foreground="White" FontWeight="Bold">
                            <Run Text="Creators (" /><Run Text="{Binding Creators.Count, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>
                    </Border>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Creators}"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="32" Height="32" CornerRadius="16" ClipToBounds="True"
                                            Background="{DynamicResource ListItemsMouseHoverColorAccordingTheme}">
                                        <Image Stretch="UniformToFill">
                                            <Image.Source>
                                                <Binding Path="AvatarUrl" />
                                            </Image.Source>
                                        </Image>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="Bold"
                                                   Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock FontSize="11" Opacity="0.7"
                                                   Foreground="{DynamicResource TextColorBrushAccordingTheme}">
                                            <Run Text="@" /><Run Text="{Binding Handle}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Margin="10,5"
                   Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
