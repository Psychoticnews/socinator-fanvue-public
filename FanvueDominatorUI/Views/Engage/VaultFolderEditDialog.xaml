<Window
    x:Class="FanvueDominatorUI.Views.Engage.VaultFolderEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Folder"
    Width="380" Height="170"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Background="{DynamicResource UserControlBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Margin="0,0,0,6"
                   Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                   Text="Folder name" />
        <TextBox Grid.Row="1" Name="NameTextBox"
                 Padding="6,4"
                 Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                 Background="{DynamicResource UserControlBackgroundBrush}"
                 BorderBrush="{DynamicResource TabBorderSolidBrush}" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="OkButton" Width="90" Padding="14,4" Margin="0,0,8,0"
                    IsDefault="True" Click="OkButton_Click"
                    Content="OK" />
            <Button Name="CancelButton" Width="90" Padding="14,4"
                    IsCancel="True" Click="CancelButton_Click"
                    Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
