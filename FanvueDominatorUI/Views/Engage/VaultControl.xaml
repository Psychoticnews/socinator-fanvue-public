<UserControl
    x:Class="FanvueDominatorUI.Views.Engage.VaultControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:FanvueDominatorUI.ViewModels.Engage"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="900">
    <UserControl.DataContext>
        <vm:VaultViewModel />
    </UserControl.DataContext>
    <Grid Background="{DynamicResource UserControlBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                           Text="{DynamicResource LangKeyAccount}" />
                <ComboBox Width="220"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount}"
                          DisplayMemberPath="Display" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Padding="14,4" Margin="0,0,8,0"
                        Command="{Binding AddFolderCommand}"
                        Content="+ New Folder" />
                <Button Padding="14,4"
                        Command="{Binding RefreshCommand}"
                        Content="{DynamicResource LangKeyRefresh}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="10,0,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderThickness="1"
                    BorderBrush="{DynamicResource TabBorderSolidBrush}">
                <ListBox ItemsSource="{Binding Folders}"
                         SelectedItem="{Binding SelectedFolder}"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold"
                                               Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                                               Text="{Binding Name}" />
                                    <TextBlock FontSize="11" Opacity="0.7"
                                               Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                                               Text="{Binding CreatedAt, StringFormat='{}{0:d}'}" />
                                </StackPanel>
                                <Border Grid.Column="1" VerticalAlignment="Center" Margin="0,0,6,0"
                                        Background="{DynamicResource AccentBaseColorBrush}"
                                        CornerRadius="9" Padding="6,2">
                                    <TextBlock Foreground="White" FontSize="10" Text="{Binding MediaCount}" />
                                </Border>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Padding="6,2" Margin="0,0,4,0" FontSize="10"
                                            Content="Rename"
                                            Command="{Binding DataContext.RenameFolderCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                    <Button Padding="6,2" FontSize="10"
                                            Content="Delete"
                                            Command="{Binding DataContext.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button Grid.Row="0" Padding="14,4" Margin="0,0,0,6"
                        HorizontalAlignment="Left"
                        Command="{Binding AddMediaCommand}"
                        Content="+ Add Media" />
                <Border Grid.Row="1" BorderThickness="1"
                        BorderBrush="{DynamicResource TabBorderSolidBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Media}" Margin="6">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4" Width="120" Height="120"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource TabBorderSolidBrush}">
                                        <Grid>
                                            <Image Stretch="UniformToFill">
                                                <Image.Source>
                                                    <Binding Path="ThumbnailUrl" />
                                                </Image.Source>
                                            </Image>
                                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Width="22" Height="22" Margin="2"
                                                    Padding="0" FontSize="11" FontWeight="Bold"
                                                    Background="#C0000000" Foreground="White"
                                                    BorderThickness="0"
                                                    Content="X"
                                                    ToolTip="Remove from folder"
                                                    CommandParameter="{Binding}"
                                                    Command="{Binding DataContext.RemoveMediaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                            <Border VerticalAlignment="Bottom"
                                                    Background="#80000000" Padding="4,2">
                                                <TextBlock Foreground="White" FontSize="10"
                                                           Text="{Binding MediaType}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" Margin="10,5"
                   Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
