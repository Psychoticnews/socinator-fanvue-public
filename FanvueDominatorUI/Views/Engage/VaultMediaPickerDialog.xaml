<Window
    x:Class="FanvueDominatorUI.Views.Engage.VaultMediaPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Select Media"
    Width="640" Height="520"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    Background="{DynamicResource UserControlBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Name="HeaderText" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextColorBrushAccordingTheme}"
                   Text="Loading..." />

        <Border Grid.Row="1" BorderThickness="1"
                BorderBrush="{DynamicResource TabBorderSolidBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl Name="MediaItems" Margin="6">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" Width="100" Height="100"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource TabBorderSolidBrush}">
                                <Grid>
                                    <Image Stretch="UniformToFill">
                                        <Image.Source>
                                            <Binding Path="ThumbnailUrl" />
                                        </Image.Source>
                                    </Image>
                                    <CheckBox HorizontalAlignment="Right" VerticalAlignment="Top"
                                              Margin="4"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                    <Border VerticalAlignment="Bottom"
                                            Background="#80000000" Padding="4,2">
                                        <TextBlock Foreground="White" FontSize="10"
                                                   Text="{Binding MediaType}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="2" Name="StatusText" Margin="0,8,0,0"
                   Foreground="{DynamicResource TextColorBrushAccordingTheme}" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Name="OkButton" Width="100" Padding="14,4" Margin="0,0,8,0"
                    IsDefault="True" Click="OkButton_Click"
                    Content="Add Selected" />
            <Button Name="CancelButton" Width="90" Padding="14,4"
                    IsCancel="True" Click="CancelButton_Click"
                    Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
